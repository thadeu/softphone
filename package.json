{
  "name": "softphone",
  "private": true,
  "version": "0.0.3",
  "type": "module",
  "packageManager": "bun",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "start": "bun run build && serve dist",
    "lint": "eslint .",
